#!/bin/sh
# Maven Wrapper script for Unix/macOS
# Downloads Maven if not already cached, then runs it

set -e

MAVEN_WRAPPER_PROPERTIES="$(dirname "$0")/.mvn/wrapper/maven-wrapper.properties"

if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
    MAVEN_DIST_URL=$(grep 'distributionUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
fi

MAVEN_DIST_URL="${MAVEN_DIST_URL:-https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.zip}"

MAVEN_HOME="${HOME}/.m2/wrapper/dists/apache-maven-3.9.6"
MAVEN_CMD="${MAVEN_HOME}/bin/mvn"

if [ ! -f "$MAVEN_CMD" ]; then
    echo "Downloading Maven..."
    mkdir -p "$(dirname "$MAVEN_HOME")"
    TMPFILE=$(mktemp /tmp/maven-wrapper-XXXXXX.zip)
    curl -fsSL -o "$TMPFILE" "$MAVEN_DIST_URL"
    unzip -q -o "$TMPFILE" -d "$(dirname "$MAVEN_HOME")"
    rm -f "$TMPFILE"
    echo "Maven downloaded to $MAVEN_HOME"
fi

exec "$MAVEN_CMD" "$@"
